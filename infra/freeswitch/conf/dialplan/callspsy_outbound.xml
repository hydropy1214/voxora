<include>
  <context name="callspsy_outbound">

    <!--
      ================================================================
      CallsPsy Outbound Call Dialplan

      Call flow:
        1. CampaignProcessor calls ESL originate with &park()
        2. FreeSWITCH dials via registered gateway
        3. On answer: execute_on_answer triggers AMD Lua
        4. AMD Lua detects HUMAN/MACHINE, plays audio, hangs up
        5. ESL events flow back to SipService for DB updates

      Channel variables set by CampaignProcessor ESL originate:
        callspsy_campaign_id   — Campaign UUID
        callspsy_call_log_id   — CallLog UUID (for DB update)
        callspsy_audio_file    — Absolute path to audio file (shared volume)
        callspsy_voicemail_audio — Absolute path to voicemail audio
        callspsy_amd_action    — PLAY_ON_HUMAN|VOICEMAIL_DROP|HANGUP_ON_MACHINE|PLAY_ON_BOTH
        callspsy_gateway       — SIP account UUID (= gateway name)
      ================================================================
    -->

    <!-- ── Main outbound call extension ────────────────────────────── -->
    <extension name="callspsy_broadcast" continue="false">
      <condition field="destination_number" expression="^(\+?[0-9]{7,15})$" break="on-true">

        <!-- Caller ID (set by ESL via origination_caller_id_* vars) -->
        <action application="set" data="effective_caller_id_number=${origination_caller_id_number}"/>
        <action application="set" data="effective_caller_id_name=${origination_caller_id_name}"/>

        <!-- Call settings -->
        <action application="set" data="call_direction=outbound"/>
        <action application="set" data="hangup_after_bridge=true"/>
        <action application="set" data="continue_on_fail=false"/>
        <action application="set" data="ignore_early_media=false"/>

        <!-- Ring tone played back to the originator (cosmetic only) -->
        <action application="set" data="ringback=${us-ring}"/>

        <!-- RTP timeout: hang up if no RTP for 5 minutes -->
        <action application="set" data="rtp_timeout_sec=300"/>

        <!--
          AMD is triggered AFTER answer via execute_on_answer (set in ESL vars).
          This means FreeSWITCH first connects the call, then runs the Lua script.
          The Lua script handles all audio playback and hangup.
        -->

        <!-- Bridge to the gateway for this campaign's SIP account -->
        <action application="bridge" data="sofia/gateway/${callspsy_gateway}/${destination_number}"/>

        <!-- If bridge fails, fire completion event and hang up -->
        <action application="lua" data="/opt/callspsy/call_complete.lua"/>
        <action application="hangup"/>

      </condition>
    </extension>

    <!-- ── SIP OPTIONS keepalive response ───────────────────────────── -->
    <extension name="sip_options_response" continue="false">
      <condition field="${sip_req_method}" expression="^OPTIONS$">
        <action application="respond" data="200 OK"/>
      </condition>
    </extension>

    <!-- ── Catch-all: reject unknown destinations ────────────────────── -->
    <extension name="reject_all">
      <condition field="destination_number" expression="^.*$">
        <action application="respond" data="403 Forbidden"/>
      </condition>
    </extension>

  </context>
</include>
