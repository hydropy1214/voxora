<configuration name="modules.conf" description="FreeSWITCH Modules">
  <modules>
    <!-- Loggers -->
    <load module="mod_console"/>
    <load module="mod_logfile"/>

    <!-- Databases -->
    <load module="mod_sqlite"/>

    <!-- Endpoint modules -->
    <load module="mod_sofia"/>

    <!-- Dialplan modules -->
    <load module="mod_dialplan_xml"/>

    <!-- Application modules -->
    <load module="mod_commands"/>
    <load module="mod_dptools"/>
    <load module="mod_expr"/>
    <load module="mod_loop"/>
    <load module="mod_event_socket"/>
    <load module="mod_json_cdr"/>

    <!-- Say -->
    <load module="mod_say_en"/>

    <!-- Sound file formats -->
    <load module="mod_sndfile"/>
    <load module="mod_native_file"/>

    <!-- Codec modules -->
    <load module="mod_g723_1"/>
    <load module="mod_g729"/>
    <load module="mod_amr"/>
    <load module="mod_opus"/>
    <load module="mod_ilbc"/>

    <!-- Tone generation -->
    <load module="mod_tone_stream"/>
    <load module="mod_local_stream"/>

    <!-- TTS / DTMF -->
    <load module="mod_spandsp"/>

    <!-- Scripting -->
    <load module="mod_lua"/>

    <!-- Hash table -->
    <load module="mod_hash"/>

    <!-- CDR -->
    <load module="mod_cdr_csv"/>

    <!-- CNAM / CallerID (optional) -->
    <!-- <load module="mod_cidlookup"/> -->

    <!-- Conference (not needed for broadcasting) -->
    <!-- <load module="mod_conference"/> -->
  </modules>
</configuration>
