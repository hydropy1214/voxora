<configuration name="event_socket.conf" description="FreeSWITCH Event Socket — Voxora API">
  <settings>
    <!-- Bind to all interfaces within Docker network -->
    <param name="nat-map" value="false"/>
    <param name="listen-ip" value="0.0.0.0"/>
    <param name="listen-port" value="8021"/>
    <param name="password" value="${ESL_PASSWORD}"/>
    <!-- Only allow connections from Docker internal network -->
    <param name="apply-inbound-acl" value="lan"/>
    <param name="stop-on-bind-error" value="true"/>
  </settings>
</configuration>
