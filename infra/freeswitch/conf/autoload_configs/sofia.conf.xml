<configuration name="sofia.conf" description="FreeSWITCH Sofia SIP — CallsPsy">
  <global_settings>
    <param name="log-level"             value="0"/>
    <param name="auto-restart"          value="false"/>
    <param name="debug-presence"        value="0"/>
    <param name="rewrite-multicasted-fs-path" value="1"/>
  </global_settings>

  <profiles>
    <!--
      ================================================================
      CallsPsy Outbound SIP Profile
      
      Network layout:
        - bind to $${local_ip_v4}   (private IP, e.g. 172.x.x.x on AWS)
        - advertise $${public_ip}   (Elastic IP / public IP)
        → SDP contains public IP so provider media flows correctly
      
      Gateway configs:
        - Loaded from /var/callspsy/gateways/*.xml
        - Backend writes one XML file per SIP account
        - 'sofia profile callspsy_outbound rescan' picks them up
      ================================================================
    -->
    <profile name="callspsy_outbound">
      <domains>
        <domain name="all" alias="false" parse="false"/>
      </domains>

      <settings>
        <param name="debug"        value="0"/>
        <param name="sip-trace"    value="no"/>
        <param name="sip-capture"  value="no"/>

        <!-- Dialplan context for outbound calls -->
        <param name="context"      value="callspsy_outbound"/>

        <!--
          RTP/SIP binding: use private IP to bind, public IP in headers.
          This is the critical AWS NAT fix:
            local_ip_v4 = private (e.g. 10.0.1.5)
            public_ip   = Elastic IP (e.g. 54.x.x.x)
        -->
        <param name="rtp-ip"       value="$${local_ip_v4}"/>
        <param name="sip-ip"       value="$${local_ip_v4}"/>
        <param name="ext-rtp-ip"   value="$${public_ip}"/>
        <param name="ext-sip-ip"   value="$${public_ip}"/>

        <!-- SIP port — 5080 to avoid conflict with Kamailio on 5060 -->
        <param name="sip-port"     value="5080"/>
        <param name="tls-sip-port" value="5081"/>

        <!-- Identify as CallsPsy in User-Agent header -->
        <param name="user-agent-string" value="CallsPsy/1.0 (FreeSWITCH)"/>

        <!-- Codec preferences: G711 first (most provider compatible) -->
        <param name="inbound-codec-prefs"  value="PCMU,PCMA,G722"/>
        <param name="outbound-codec-prefs" value="PCMU,PCMA,G722"/>

        <!-- NAT: trust private address ranges -->
        <param name="local-network-acl"    value="localnet.auto"/>
        <param name="apply-nat-acl"        value="natmap.auto"/>
        <param name="aggressive-nat-detection" value="true"/>
        <param name="nat-options-ping"     value="true"/>

        <!-- RTP port range -->
        <param name="rtp-timeout-sec"      value="300"/>
        <param name="rtp-hold-timeout-sec" value="1800"/>

        <!-- DTMF -->
        <param name="dtmf-duration"   value="2000"/>
        <param name="rfc2833-pt"      value="101"/>
        <param name="dtmf-type"       value="rfc2833"/>
        <param name="pass-rfc2833"    value="true"/>

        <!-- Call behavior -->
        <param name="max-proceeding"            value="10000"/>
        <param name="inbound-late-negotiation"  value="true"/>
        <param name="enable-100rel"             value="false"/>
        <param name="enable-timer"              value="false"/>
        <param name="session-timeout"           value="1800"/>
        <param name="caller-id-type"            value="pid"/>
        <param name="suppress-cng"              value="true"/>
        <param name="send-silence-when-idle"    value="-1"/>

        <!-- No registration on this profile itself (gateways register) -->
        <param name="auth-calls"         value="false"/>
        <param name="accept-blind-reg"   value="false"/>
        <param name="accept-blind-auth"  value="false"/>
        <param name="manage-presence"    value="false"/>

        <!-- Recordings -->
        <param name="record-path"     value="/var/lib/freeswitch/recordings"/>
        <param name="record-template" value="${strftime(%Y/%m/%d)}/${uuid}.wav"/>

        <!-- No STUN (we use explicit public IP above) -->
        <param name="stun-enabled"       value="false"/>
        <param name="stun-auto-disable"  value="true"/>

        <!-- TLS — enabled for providers like Vonage Edge that require SIP-TLS -->
        <param name="tls"                    value="true"/>
        <param name="tls-sip-port"           value="5081"/>
        <param name="tls-version"            value="tlsv1,tlsv1.1,tlsv1.2,tlsv1.3"/>
        <param name="tls-cert-dir"           value="/etc/freeswitch/tls"/>
        <param name="tls-verify-date"        value="true"/>
        <param name="tls-verify-policy"      value="none"/>
        <param name="tls-verify-depth"       value="2"/>
        <param name="tls-passphrase"         value=""/>
        <param name="tls-bind-params"        value="transport=tls"/>
      </settings>

      <gateways>
        <!--
          Per-account gateways are loaded from the shared volume.
          Backend writes /var/callspsy/gateways/<account-id>.xml
          and calls: sofia profile callspsy_outbound rescan
        -->
        <X-PRE-PROCESS cmd="include" data="/var/callspsy/gateways/*.xml"/>
      </gateways>
    </profile>
  </profiles>
</configuration>
