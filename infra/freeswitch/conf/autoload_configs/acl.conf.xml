<configuration name="acl.conf" description="Network Access Control Lists">
  <network-lists>

    <!-- Trusted local networks -->
    <list name="lan" default="allow">
      <node type="allow" cidr="127.0.0.0/8"/>
      <node type="allow" cidr="10.0.0.0/8"/>
      <node type="allow" cidr="172.16.0.0/12"/>
      <node type="allow" cidr="192.168.0.0/16"/>
    </list>

    <!-- Loopback only (for ESL) -->
    <list name="loopback.auto" default="deny">
      <node type="allow" cidr="127.0.0.1/32"/>
    </list>

    <!-- Allow all (outbound calls go everywhere) -->
    <list name="any_v4.auto" default="allow">
      <node type="allow" cidr="0.0.0.0/0"/>
    </list>

    <!-- NAT map — mark these as needing NAT translation -->
    <list name="natmap.auto" default="deny">
      <node type="allow" cidr="10.0.0.0/8"/>
      <node type="allow" cidr="172.16.0.0/12"/>
      <node type="allow" cidr="192.168.0.0/16"/>
    </list>

    <!-- localnet — private IP ranges -->
    <list name="localnet.auto" default="allow">
      <node type="allow" cidr="10.0.0.0/8"/>
      <node type="allow" cidr="172.16.0.0/12"/>
      <node type="allow" cidr="192.168.0.0/16"/>
      <node type="allow" cidr="127.0.0.0/8"/>
    </list>

  </network-lists>
</configuration>
