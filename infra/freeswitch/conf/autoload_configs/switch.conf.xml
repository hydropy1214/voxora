<configuration name="switch.conf" description="Core FreeSWITCH Configuration">
  <settings>
    <!-- Core threading -->
    <param name="default-voicemail-extension" value="vmain"/>
    <param name="sessions-per-second" value="500"/>
    <param name="max-sessions" value="10000"/>
    <param name="rtp-start-port" value="10000"/>
    <param name="rtp-end-port" value="20000"/>

    <!-- Logging -->
    <param name="loglevel" value="warning"/>
    <param name="max-db-handles" value="50"/>
    <param name="db-handle-timeout" value="10"/>
    <param name="max-audio-channels" value="0"/>

    <!-- Timing -->
    <param name="min-idle-cpu" value="0"/>

    <!-- SIP -->
    <param name="enable-use-soa" value="true"/>
    <param name="enable-zrtp" value="false"/>

    <!-- CDR -->
    <param name="colorize-console" value="true"/>
    <param name="auto-create-schemas" value="true"/>
    <param name="auto-migrate-schemas" value="true"/>

    <!-- RTP timer -->
    <param name="rtp-enable-zrtp" value="false"/>

    <!-- Avoid SDP manipulation issues on AWS -->
    <param name="nat-map" value="false"/>
    <param name="stun-enabled" value="false"/>
    <param name="stun-auto-disable" value="true"/>
  </settings>
</configuration>
