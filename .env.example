# ===================================
# VOXORA - Environment Configuration
# ===================================

# App
NODE_ENV=production
APP_PORT=3001
APP_URL=https://app.voxora.io
FRONTEND_URL=https://app.voxora.io

# JWT
JWT_SECRET=change-me-super-secret-jwt-key-32chars
JWT_REFRESH_SECRET=change-me-super-secret-refresh-key
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Database
DATABASE_URL=postgresql://voxora:voxora_pass@postgres:5432/voxora_db?schema=public

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=voxora_redis_pass

# Mail
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USER=postmaster@mg.voxora.io
MAIL_PASS=your-mailgun-password
MAIL_FROM=noreply@voxora.io

# Storage (S3-compatible)
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=/app/uploads
S3_BUCKET=voxora-uploads
S3_REGION=us-east-1
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_ENDPOINT=https://s3.amazonaws.com

# FreeSWITCH ESL
FREESWITCH_HOST=freeswitch
FREESWITCH_ESL_PORT=8021
FREESWITCH_ESL_PASSWORD=ClueCon

# Kamailio
KAMAILIO_HOST=kamailio
KAMAILIO_RPC_PORT=5060

# RTPengine
RTPENGINE_HOST=rtpengine
RTPENGINE_PORT=2223

# Coturn
COTURN_HOST=coturn
COTURN_PORT=3478
COTURN_SECRET=change-me-coturn-secret

# Stripe (Billing)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_TRIAL=price_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=http://localhost:3001
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
